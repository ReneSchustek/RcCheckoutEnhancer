<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/System/SystemConfig/Schema/config.xsd">

    <card>
        <title>Fortschrittsanzeige</title>
        <title lang="en-GB">Progress Bar</title>

        <input-field type="bool">
            <name>progressBarEnabled</name>
            <label>Fortschrittsanzeige aktivieren</label>
            <label lang="en-GB">Enable progress bar</label>
            <helpText>Zeigt eine Schritt-für-Schritt-Anzeige im Checkout.</helpText>
            <helpText lang="en-GB">Shows a step-by-step indicator in the checkout.</helpText>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="text">
            <name>progressStep1</name>
            <label>Schritt 1 – Bezeichnung</label>
            <label lang="en-GB">Step 1 – Label</label>
            <placeholder>Warenkorb</placeholder>
            <placeholder lang="en-GB">Cart</placeholder>
            <helpText>Leer lassen für Standard-Snippet.</helpText>
            <helpText lang="en-GB">Leave empty for default snippet.</helpText>
        </input-field>

        <input-field type="text">
            <name>progressStep2</name>
            <label>Schritt 2 – Bezeichnung</label>
            <label lang="en-GB">Step 2 – Label</label>
            <placeholder>Adresse &amp; Versand</placeholder>
            <placeholder lang="en-GB">Address &amp; Shipping</placeholder>
        </input-field>

        <input-field type="text">
            <name>progressStep3</name>
            <label>Schritt 3 – Bezeichnung</label>
            <label lang="en-GB">Step 3 – Label</label>
            <placeholder>Prüfen &amp; Bestellen</placeholder>
            <placeholder lang="en-GB">Review &amp; Order</placeholder>
        </input-field>

        <input-field type="text">
            <name>progressStep4</name>
            <label>Schritt 4 – Bezeichnung</label>
            <label lang="en-GB">Step 4 – Label</label>
            <placeholder>Abgeschlossen</placeholder>
            <placeholder lang="en-GB">Complete</placeholder>
        </input-field>
    </card>

    <card>
        <title>Vertrauenssignale</title>
        <title lang="en-GB">Trust Badges</title>

        <input-field type="bool">
            <name>trustBadgesEnabled</name>
            <label>Vertrauenssignale aktivieren</label>
            <label lang="en-GB">Enable trust badges</label>
            <helpText>Zeigt konfigurierbare Vertrauenssignale im Checkout.</helpText>
            <helpText lang="en-GB">Shows configurable trust badges in the checkout.</helpText>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="textarea">
            <name>trustBadges</name>
            <label>Vertrauenssignale (eines pro Zeile)</label>
            <label lang="en-GB">Trust badges (one per line)</label>
            <helpText>Format: icon;Text (Icon optional). Verfügbare Icons: lock, truck, undo. Beispiel: lock;Sichere Bestellung</helpText>
            <helpText lang="en-GB">Format: icon;Text (icon optional). Available icons: lock, truck, undo. Example: lock;Secure order</helpText>
            <defaultValue>lock;Sichere Bestellung (SSL-verschlüsselt)
truck;Kostenloser Versand ab 50 €
undo;14 Tage Widerrufsrecht</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Warenkorbübersicht</title>
        <title lang="en-GB">Cart Overview</title>

        <input-field type="bool">
            <name>miniCartEnabled</name>
            <label>Mini-Warenkorb im Checkout anzeigen</label>
            <label lang="en-GB">Show mini cart in checkout</label>
            <helpText>Zeigt eine kompakte Warenkorbübersicht auf der Bestätigungsseite.</helpText>
            <helpText lang="en-GB">Shows a compact cart overview on the confirmation page.</helpText>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Bestellzusammenfassung</title>
        <title lang="en-GB">Order Summary</title>

        <input-field type="bool">
            <name>orderSummaryEnabled</name>
            <label>Bestellzusammenfassung anzeigen</label>
            <label lang="en-GB">Show order summary</label>
            <helpText>Zeigt Adresse, Versand und Zahlung kompakt vor dem Bestellen-Button.</helpText>
            <helpText lang="en-GB">Shows address, shipping and payment compactly before the order button.</helpText>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>deliveryTimeEnabled</name>
            <label>Geschätzte Lieferzeit anzeigen</label>
            <label lang="en-GB">Show estimated delivery time</label>
            <defaultValue>false</defaultValue>
        </input-field>

        <input-field type="text">
            <name>estimatedDeliveryTime</name>
            <label>Geschätzte Lieferzeit</label>
            <label lang="en-GB">Estimated delivery time</label>
            <placeholder>3-5 Werktage</placeholder>
            <placeholder lang="en-GB">3-5 business days</placeholder>
            <helpText>Wird nur angezeigt wenn das Lieferzeit-Feature aktiv ist.</helpText>
            <helpText lang="en-GB">Only shown when the delivery time feature is active.</helpText>
        </input-field>
    </card>
</config>
