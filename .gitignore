# ============================================================
# .gitignore – RcCheckoutEnhancer
# ============================================================
# Hinweis: AI-Artefakte, STATUS.md, briefs/, DEPLOYMENT.md,
# zugaenge.md usw. sind in ~/.gitignore_global eingetragen
# und müssen hier NICHT wiederholt werden.
# ============================================================

# ============================================================
# Hinweis: reviews/ gehört NICHT in .gitignore
# ============================================================
# reviews/ wird auf DevBox in Git versioniert (Entwicklungshistorie).
# GitHub-Export-Script schließt reviews/ automatisch aus.
# Niemals reviews/ hier eintragen.
# ============================================================

# ============================================================
# Secrets / Umgebungsvariablen (NIEMALS in Git!)
# ============================================================
.env
.env.local
.env.*.local
!.env.example
secrets.json
*.pfx
*.p12
*.key
config/secrets/

# ============================================================
# Logs
# ============================================================
*.log
/logs/

# ============================================================
# PHP / Shopware
# ============================================================
/vendor/
/var/
/node_modules/
